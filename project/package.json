{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "vite build --config config/vite.config.ts && node scripts/generate-sitemap.mjs",
    "lint": "eslint . --config config/eslint.config.js",
    "preview": "vite preview --config config/vite.config.ts",
    "typecheck": "tsc --noEmit -p config/tsconfig.app.json",
    "perf:collect": "lhci collect --config=lighthouse.config.mjs",
    "perf:assert": "lhci assert --config=lighthouse.config.mjs",
    "perf:upload": "lhci upload --config=lighthouse.config.mjs",
    "perf": "lhci autorun --config=lighthouse.config.mjs",
    "dev:ssr": "tsx server/dev.ts",
    "build:ssr": "vite build --config config/vite.config.ts --outDir dist/client && vite build --config config/vite.config.ts --ssr src/entry-server.tsx --outDir dist/server && node scripts/generate-sitemap.mjs",
    "start": "NODE_ENV=production tsx server/prod.ts"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@sentry/browser": "^10.67.0",
    "@sentry/react": "^10.67.0",
    "@supabase/supabase-js": "^2.57.4",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
