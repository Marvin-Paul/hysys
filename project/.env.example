# Supabase (required for CMS, auth, and content)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Google Tag Manager (optional — consent-gated analytics, Doc 4 §7)
# Create a container at tagmanager.google.com and paste the GTM-XXXXXXX ID here.
VITE_GTM_ID=

# Server-side scripts only (never expose in the browser)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# ADMIN_EMAIL=admin@example.com
