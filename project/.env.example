# Supabase (required for CMS, auth, and content)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Google Tag Manager (optional — consent-gated analytics, Doc 4 §7)
# Create a container at tagmanager.google.com and paste the GTM-XXXXXXX ID here.
VITE_GTM_ID=

# Sentry error tracking (optional — Doc 4 §12.11)
# Create a project at sentry.io and paste the DSN here.
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxx.ingest.sentry.io/xxxxxx

# Cloudflare Turnstile CAPTCHA (required for form spam protection — TSR-004 §5.3)
# Create a site key at https://dash.cloudflare.com/?to=/:account/turnstile
# The widget renders only when this env var is set.
VITE_TURNSTILE_SITE_KEY=

# App environment (sets Sentry environment tag; defaults to "production")
# VITE_APP_ENV=production

# Force noindex on any environment (for staging/preview deploys)
# VITE_NOINDEX=true

# Server-side scripts only (never expose in the browser)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# ADMIN_EMAIL=admin@example.com
